# Supabase — 브라우저 허용 (URL + anon key만)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Supabase — 서버 전용 (절대 NEXT_PUBLIC_ 금지)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Gemini Live API — 서버 전용
GEMINI_API_KEY=AIza...

# Vertex Live 릴레이(Cloud Run, services/vertex-live-relay) — 그룹C가 Vertex로 전환됐을 때만 사용.
# provider_switch_settings 그룹C가 ai_studio면 아래 값은 안 쓰임(기존 AI Studio 경로 그대로).
# VERTEX_LIVE_RELAY_URL=wss://<cloud-run-service>.run.app/live
# VERTEX_LIVE_RELAY_SECRET=<services/vertex-live-relay의 .env와 동일한 값>

# Vertex AI 전환(그룹A/B/C 공통) — 서버 전용, GCP_BILLING_SA_KEY_JSON과 완전 분리
# GCP_VERTEX_SA_KEY_JSON={"type":"service_account",...}
# GOOGLE_CLOUD_PROJECT=k-bestie3
# GOOGLE_CLOUD_LOCATION=us-west1

# Gemma — 서버 전용
GEMMA_API_KEY=AIza...

# GCP Speech-to-Text — 서버 전용 (아이 발화 전사, 자유대화·미션 공통 — 주기적 recognize 호출)
GCP_STT_API_KEY=AIza...

# GCP Text-to-Speech — 서버 전용 (케이 발화 합성, ko-KR-Wavenet-* 등급만 사용)
GCP_TTS_API_KEY=AIza...

# 관리자 대시보드 화이트리스트 — 콤마 구분 이메일 목록, 서버 전용
# ADMIN_EMAILS=admin1@example.com,admin2@example.com

# 아이 화면 진입 시간 제한(운영시간 게이트, /child/missions) on/off — 서버 전용.
# 값 없으면 기본 true(기존 제한 정상 적용). 테스트 기간에만 false로 설정할 것 —
# 정상 서비스 전환 시 이 줄을 지우거나 true로 바꾸면 즉시 복원된다.
# CHILD_TIME_RESTRICTIONS_ENABLED=false

# 질문·대화 엔진 V2 (PR2) 설정
# QUESTION_ENGINE_V2: true이면 질문·대화 엔진 V2를 활성화한다. 기본값은 false.
# QUESTION_ENGINE_V2=false
# QUESTION_ENGINE_V2_SEED_CHILD_IDS: 질문·대화 엔진 V2가 활성화(true)되어 있을 때, 신규 로직을 적용할 대상 아동(child_id)의 UUID 목록 (콤마 구분).
# QUESTION_ENGINE_V2_SEED_CHILD_IDS=uuid1,uuid2

# GCP billing_export(BigQuery) — 관리자 대시보드 STT/TTS 실제 청구액 조회용, 서버 전용
# 조회 전용 서비스 계정에 필요한 권한: 데이터세트 BigQuery Data Viewer + 프로젝트 BigQuery Job User
# GCP_BILLING_PROJECT_ID=K-Bestie3
# GCP_BILLING_DATASET=billing_export
# GCP_BILLING_SA_KEY_JSON={"type":"service_account",...}
