# 이 서비스(Cloud Run)가 필요로 하는 환경변수 — 값은 채우지 말 것(초안 문서 전용).
# 실제 등록은 STOP 대상: GCP Secret Manager 등록/Cloud Run 서비스 환경변수 설정은
# 대표 승인 후 별도로 진행한다.

# Next.js 앱(lib/plan/vertexLiveTicket.ts)과 반드시 동일한 값이어야 함 — 티켓 서명 검증용.
VERTEX_LIVE_RELAY_SECRET=

# 브라우저가 실제로 연결하는 우리 서비스 도메인 — 콤마로 여러 개 등록 가능.
# 예: https://k-bestie-v3.vercel.app,https://<프리뷰-배포>.vercel.app
ALLOWED_ORIGINS=

# Vertex AI 프로젝트/리전 — gemini-live-2.5-flash-native-audio 지원 리전으로 고정할 것
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-west1

# 선택 — 비워두면 Cloud Run에 첨부된 서비스계정(ADC)을 그대로 사용(권장).
# 로컬 개발에서만 채워서 쓰는 것을 권장(운영에서는 ADC 사용, 별도 키 관리 최소화).
# GCP_VERTEX_SA_KEY_JSON={"type":"service_account",...}

# 세션 최대 유지시간(ms) — 넘으면 재연결 없이 그냥 종료. 기본 30분.
# MAX_SESSION_MS=1800000

# Cloud Run이 자동 주입 — 로컬 개발시에만 직접 지정.
# PORT=8080
